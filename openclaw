#!/usr/bin/env python3
"""
openclaw CLI shim — PinchBench → ZeroClaw adapter.

Translates PinchBench's `openclaw` CLI calls into ZeroClaw gateway
HTTP requests (POST /webhook) and writes transcripts in the expected format.

No external dependencies — uses only Python stdlib.

Environment variables:
    ZEROCLAW_GATEWAY_URL    Gateway URL (default: http://localhost:42617)
    ZEROCLAW_BEARER_TOKEN   Bearer token for authentication
    ZEROCLAW_PAIRING_CODE   One-time pairing code (auto-pairs if no token)
"""

import argparse
import json
import os
import sys
import time
import urllib.error
import urllib.request
from pathlib import Path

ZEROCLAW_URL = os.environ.get("ZEROCLAW_GATEWAY_URL", "http://localhost:42617")
ZEROCLAW_TOKEN = os.environ.get("ZEROCLAW_BEARER_TOKEN", "")

AGENTS_FILE = Path.home() / ".openclaw" / "agents" / "_registry.json"
TOKEN_FILE = Path.home() / ".openclaw" / ".zeroclaw_token"


def _load_agents() -> dict:
    if AGENTS_FILE.exists():
        try:
            return json.loads(AGENTS_FILE.read_text())
        except (json.JSONDecodeError, OSError):
            pass
    return {}


def _save_agents(agents: dict) -> None:
    AGENTS_FILE.parent.mkdir(parents=True, exist_ok=True)
    AGENTS_FILE.write_text(json.dumps(agents, indent=2))


def _get_token() -> str:
    """Get bearer token, auto-pairing if needed."""
    token = ZEROCLAW_TOKEN
    if token:
        return token

    if TOKEN_FILE.exists():
        token = TOKEN_FILE.read_text().strip()
        if token:
            return token

    pairing_code = os.environ.get("ZEROCLAW_PAIRING_CODE", "")
    if not pairing_code:
        print(
            "ERROR: No bearer token. Set ZEROCLAW_BEARER_TOKEN or ZEROCLAW_PAIRING_CODE",
            file=sys.stderr,
        )
        sys.exit(1)

    req = urllib.request.Request(
        f"{ZEROCLAW_URL}/pair",
        method="POST",
        headers={
            "X-Pairing-Code": pairing_code,
            "Content-Type": "application/json",
        },
        data=b"{}",
    )
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            data = json.loads(resp.read())
            token = data.get("token", "")
            if token:
                TOKEN_FILE.parent.mkdir(parents=True, exist_ok=True)
                TOKEN_FILE.write_text(token)
                return token
    except Exception as e:
        print(f"ERROR: Auto-pairing failed: {e}", file=sys.stderr)
        sys.exit(1)

    return ""


def cmd_agents_list():
    agents = _load_agents()
    for agent_id, info in agents.items():
        workspace = info.get("workspace", "~/.openclaw/workspace")
        print(f"- {agent_id}")
        print(f"    Workspace: {workspace}")


def cmd_agents_add(agent_id: str, model: str, workspace: str):
    # Override workspace to match ZeroClaw's config.workspace_dir so that
    # PinchBench copies fixtures to the same directory ZeroClaw's tools write to.
    zeroclaw_workspace = os.environ.get("ZEROCLAW_WORKSPACE", "/tmp/pinchbench")
    effective_workspace = os.path.join(zeroclaw_workspace, "workspace")
    agents = _load_agents()
    agents[agent_id] = {"model": model, "workspace": effective_workspace}
    _save_agents(agents)
    Path(effective_workspace).mkdir(parents=True, exist_ok=True)
    sessions_dir = (
        Path.home()
        / ".openclaw"
        / "agents"
        / agent_id.replace(":", "-").lower()
        / "sessions"
    )
    sessions_dir.mkdir(parents=True, exist_ok=True)


def cmd_agents_delete(agent_id: str):
    agents = _load_agents()
    normalized = agent_id.replace(":", "-").lower()
    agents.pop(agent_id, None)
    agents.pop(normalized, None)
    _save_agents(agents)


def cmd_agent_message(agent_id: str, session_id: str, message: str):
    """Send a message to ZeroClaw via POST /webhook and write transcript."""
    token = _get_token()

    transcript_entries = []

    # Record user message
    transcript_entries.append(
        {
            "type": "message",
            "message": {"role": "user", "content": message},
            "timestamp": time.time(),
        }
    )

    # Call ZeroClaw webhook
    url = f"{ZEROCLAW_URL}/webhook"
    payload = json.dumps({"message": message}).encode("utf-8")
    headers = {
        "Content-Type": "application/json",
        "Authorization": f"Bearer {token}",
        "X-Session-Id": session_id,
    }

    full_response = ""
    start = time.time()
    try:
        req = urllib.request.Request(url, data=payload, headers=headers, method="POST")
        with urllib.request.urlopen(req, timeout=600) as resp:
            data = json.loads(resp.read())
            full_response = data.get("response", "")
    except urllib.error.HTTPError as e:
        body = e.read().decode("utf-8", errors="replace")
        full_response = f"[HTTP {e.code}] {body}"
    except Exception as e:
        full_response = f"[Error] {e}"

    elapsed = time.time() - start

    # Record assistant response
    transcript_entries.append(
        {
            "type": "message",
            "message": {
                "role": "assistant",
                "content": full_response,
                "usage": {
                    "input": 0,
                    "output": 0,
                    "totalTokens": 0,
                    "cost": {"total": 0.0},
                },
            },
            "timestamp": time.time(),
        }
    )

    # Write transcript JSONL
    agent_dir = (
        Path.home()
        / ".openclaw"
        / "agents"
        / agent_id.replace(":", "-").lower()
    )
    sessions_dir = agent_dir / "sessions"
    sessions_dir.mkdir(parents=True, exist_ok=True)

    transcript_path = sessions_dir / f"{session_id}.jsonl"
    with open(transcript_path, "a") as f:
        for entry in transcript_entries:
            f.write(json.dumps(entry) + "\n")

    # Update sessions.json so PinchBench can find the transcript
    sessions_store = sessions_dir / "sessions.json"
    store_data = {}
    if sessions_store.exists():
        try:
            store_data = json.loads(sessions_store.read_text())
        except (json.JSONDecodeError, OSError):
            pass

    store_data[f"agent:{agent_id}:main"] = {
        "sessionId": session_id,
        "updatedAt": time.time(),
    }
    sessions_store.write_text(json.dumps(store_data, indent=2))

    # Print response to stdout
    print(full_response)


def main():
    if len(sys.argv) < 2:
        print("Usage: openclaw <command> [args]", file=sys.stderr)
        sys.exit(1)

    cmd = sys.argv[1]

    if cmd == "agents":
        if len(sys.argv) < 3:
            print("Usage: openclaw agents <list|add|delete>", file=sys.stderr)
            sys.exit(1)

        subcmd = sys.argv[2]
        if subcmd == "list":
            cmd_agents_list()
        elif subcmd == "add":
            parser = argparse.ArgumentParser()
            parser.add_argument("name")
            parser.add_argument("--model", default="default")
            parser.add_argument("--workspace", default="")
            parser.add_argument("--non-interactive", action="store_true")
            args = parser.parse_args(sys.argv[3:])
            cmd_agents_add(args.name, args.model, args.workspace)
        elif subcmd == "delete":
            agent_id = sys.argv[3] if len(sys.argv) > 3 else ""
            cmd_agents_delete(agent_id)

    elif cmd == "agent":
        parser = argparse.ArgumentParser()
        parser.add_argument("--agent", required=True)
        parser.add_argument("--session-id", default="default")
        parser.add_argument("--message", required=True)
        args = parser.parse_args(sys.argv[2:])
        cmd_agent_message(args.agent, args.session_id, args.message)

    else:
        print(f"Unknown command: {cmd}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
